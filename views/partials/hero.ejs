<section class="bg-white border-b border-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Hero Content -->
      <div class="lg:pr-12">
        <div class="inline-flex items-center px-4 py-2 rounded-full text-sm font-semibold bg-blue-50 text-blue-700 mb-6">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
          </svg>
          Datos actualizados diariamente
        </div>
        
        <h1 class="text-4xl lg:text-6xl font-bold text-gray-900 leading-tight mb-6">
          Comparador de <span class="text-blue-600">Créditos</span><br>
          Bancarios Chile
        </h1>
        
        <p class="text-xl text-gray-600 mb-8 max-w-lg leading-relaxed">
          Encuentre objetivamente las mejores ofertas de créditos de consumo. 
          Compare CAE, tasas y condiciones de 6 principales bancos chilenos.
        </p>
        
        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 mb-12 p-6 bg-gray-50 rounded-xl">
          <div class="text-center">
            <div class="text-3xl font-bold text-blue-600 mb-1"><%= total %></div>
            <div class="text-sm font-medium text-gray-600 uppercase tracking-wide">Créditos Disponibles</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-green-600 mb-1">11.8%</div>
            <div class="text-sm font-medium text-gray-600 uppercase tracking-wide">Mejor CAE</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-gray-600 mb-1">6</div>
            <div class="text-sm font-medium text-gray-600 uppercase tracking-wide">Bancos</div>
          </div>
        </div>
        
        <!-- CTA -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#filtros" class="inline-flex items-center justify-center px-8 py-4 bg-blue-600 text-white font-bold text-lg rounded-xl hover:bg-blue-700 transition-all duration-200 shadow-lg hover:shadow-xl w-full sm:w-auto">
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
            </svg>
            Buscar Ofertas
          </a>
        </div>
      </div>
      
      <!-- Hero Visual - Preview -->
      <div class="relative">
        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900 mb-6 text-center">Vista Previa Resultados</h3>
          <div class="overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-white">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Banco</th>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">CAE</th>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Tasa</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% if (creditos && creditos.length > 0) { %>
                  <% creditos.slice(0,3).forEach(credito => { %>
                    <tr class="hover:bg-gray-50">
                      <td class="px-4 py-4 font-medium text-gray-900"><%= credito.banco %></td>
                      <td class="px-4 py-4">
                        <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-800">
                          <%= credito.cae %>
                        </span>
                      </td>
                      <td class="px-4 py-4 text-sm text-gray-700"><%= credito.tasa %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="3" class="px-4 py-8 text-center text-gray-500 text-sm">Aplica filtros para ver ofertas</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
:root {
  --navy-600: #1e40af;
}
.fade-in {
  animation: fadeIn 0.6s ease-out;
}
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>
