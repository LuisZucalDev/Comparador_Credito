<section class="relative min-h-[85vh] flex items-center pt-40 pb-24 overflow-hidden">
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Executive Content -->
      <div class="slide-up">
        <div class="inline-flex items-center px-4 py-2 rounded-2xl text-[9px] font-black bg-white dark:bg-slate-900 text-slate-800 dark:text-white border border-white/40 dark:border-slate-800/40 mb-16 sm:mb-12 shadow-elite tracking-[0.3em] uppercase animate-fade-in relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-emerald-500/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
          <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full mr-3 animate-pulse shadow-glow-emerald"></span>
          <span class="relative z-10 opacity-70 group-hover:opacity-100 transition-opacity"><%= t('hero.badge') %></span>
        </div>
        
        <h1 class="text-4xl sm:text-7xl lg:text-8xl 2xl:text-[8.5rem] font-display font-black text-slate-900 dark:text-white leading-[1.1] sm:leading-[1] 2xl:leading-[0.9] mb-10 tracking-tighter">
          <%= t('hero.title_part1') %><br>
          <span class="text-transparent bg-gradient-to-br from-navy-800 via-indigo-600 to-indigo-400 dark:from-white dark:via-indigo-300 dark:to-indigo-100 bg-clip-text"><%= t('hero.title_part2') %></span><br>
          <span class="text-2xl sm:text-5xl lg:text-6xl 2xl:text-7xl text-slate-300 dark:text-slate-700 font-light font-sans mt-2 block italic"><%= t('hero.title_part3') %></span>
        </h1>
        
        <p class="text-xl lg:text-2xl 2xl:text-3xl text-slate-500 dark:text-slate-400 mb-16 max-w-xl 2xl:max-w-3xl leading-relaxed font-medium opacity-90">
          <%= t('hero.description') %>
        </p>
        
        <!-- Elite Stats Center -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0 rounded-6xl overflow-hidden border border-white/40 dark:border-slate-800/60 shadow-elite bg-white/40 dark:bg-slate-900/40 backdrop-blur-xl mb-16">
          <div class="p-8 md:p-12 2xl:p-16 border-b md:border-b-0 md:border-r border-slate-200/50 dark:border-slate-800/40 group hover:bg-white/40 dark:hover:bg-slate-800/40 transition-all duration-700">
            <div class="text-4xl md:text-5xl 2xl:text-7xl font-display font-black text-slate-900 dark:text-white mb-2 group-hover:translate-x-1 transition-transform origin-left text-center md:text-left"><%= stats ? stats.total : '25+' %></div>
            <div class="text-[10px] 2xl:text-xs font-black text-navy-500 dark:text-navy-400 uppercase tracking-[0.3em] text-center md:text-left opacity-60 group-hover:opacity-100"><%= t('hero.active_offers') %></div>
          </div>
          <div class="p-8 md:p-12 2xl:p-16 border-b md:border-b-0 md:border-r border-slate-200/50 dark:border-slate-800/40 group hover:bg-white/40 dark:hover:bg-slate-800/40 transition-all duration-700">
            <div class="text-4xl md:text-5xl 2xl:text-7xl font-display font-black text-emerald-500 dark:text-emerald-400 mb-2 group-hover:translate-x-1 transition-transform origin-left text-center md:text-left"><%= stats ? stats.mejorCAE : '11.8%' %></div>
            <div class="text-[10px] 2xl:text-xs font-black text-navy-500 dark:text-navy-400 uppercase tracking-[0.3em] text-center md:text-left opacity-60 group-hover:opacity-100"><%= t('hero.best_cae') %></div>
          </div>
          <div class="p-8 md:p-12 2xl:p-16 group hover:bg-white/40 dark:hover:bg-slate-800/40 transition-all duration-700">
            <div class="text-4xl md:text-5xl 2xl:text-7xl font-display font-black text-slate-900 dark:text-white mb-2 group-hover:translate-x-1 transition-transform origin-left text-center md:text-left">6</div>
            <div class="text-[10px] 2xl:text-xs font-black text-navy-500 dark:text-navy-400 uppercase tracking-[0.3em] text-center md:text-left opacity-60 group-hover:opacity-100"><%= t('hero.analyzed_banks') %></div>
          </div>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-8">
          <a href="#filtros" class="btn-executive text-xl lg:text-3xl py-7 px-16 tracking-tighter shadow-glow-brand group relative">
            <span class="relative z-10 flex items-center">
              <%= t('hero.cta') %>
              <svg class="w-6 h-6 ml-4 group-hover:translate-x-2 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </a>
        </div>
      </div>
      
      <!-- Luxury Visualizer -->
      <div class="relative hidden lg:block fade-in" style="animation-delay: 0.3s;">
        <div class="relative z-20">
          <div class="glass-elite rounded-6xl p-12 lg:p-16 border-white/60 shadow-soft-glow max-w-lg mx-auto group perspective-1000">
            <div class="flex items-center justify-between mb-12">
              <div>
                <h3 class="text-2xl font-display font-black text-slate-900 dark:text-white tracking-tight"><%= t('hero.example_title') %></h3>
                <div class="w-10 h-1 bg-gradient-to-r from-emerald-400 to-indigo-400 rounded-full mt-2"></div>
              </div>
              <div class="flex space-x-2">
                <div class="w-3 h-3 rounded-full bg-slate-200 dark:bg-slate-800 animate-pulse"></div>
                <div class="w-3 h-3 rounded-full bg-slate-200 dark:bg-slate-800 animate-pulse-slow"></div>
              </div>
            </div>
            
            <div class="space-y-8">
              <% if (creditos && creditos.length > 0) { %>
                <% creditos.slice(0, 3).forEach((credito, index) => { %>
                  <div class="flex items-center p-6 bg-white/40 dark:bg-slate-800/20 rounded-4xl border border-white/60 dark:border-slate-800/40 hover:bg-white dark:hover:bg-slate-800 hover:scale-[1.08] hover:-rotate-1 hover:shadow-glow-brand transition-all duration-700 group/item cursor-default" 
                       style="--glow-color: <%= index === 0 ? 'rgba(0,51,153,0.15)' : index === 1 ? 'rgba(236,0,0,0.15)' : 'rgba(0,60,255,0.15)' %>">
                    <div class="w-14 h-14 bg-white dark:bg-slate-900 rounded-3xl flex items-center justify-center mr-6 shadow-elite group-hover/item:rotate-12 transition-transform duration-700">
                      <span class="text-3xl filter drop-shadow-lg"><%= ['🏛️','🏦','🏢'][index % 3] %></span>
                    </div>
                    <div class="flex-1">
                      <div class="font-display font-black text-xl text-slate-900 dark:text-white leading-none mb-1.5 uppercase tracking-tight"><%= t('banks.' + credito.banco) %></div>
                      <div class="flex items-center space-x-4">
                        <span class="text-emerald-500 font-black text-sm tabular-nums"><%= credito.cae %> CAE</span>
                        <div class="w-1 h-1 bg-slate-200 dark:bg-slate-700 rounded-full"></div>
                        <span class="text-slate-400 text-[10px] font-black uppercase tracking-widest opacity-80"><%= credito.plazo %> MESES</span>
                      </div>
                    </div>
                  </div>
                <% }) %>
              <% } %>
            </div>
            
            <div class="mt-12 p-6 bg-slate-100/50 dark:bg-white/5 rounded-4xl border border-white/20 dark:border-slate-800 text-center overflow-hidden relative group/loader">
              <div class="absolute inset-0 bg-gradient-to-r from-transparent via-indigo-500/10 to-transparent -translate-x-full animate-shimmer"></div>
              <span class="relative z-10 text-slate-500 dark:text-slate-400 font-black uppercase tracking-[0.4em] text-[9px]">
                System Analytics Active <span class="animate-pulse">●</span>
              </span>
            </div>
          </div>
          <!-- Decorative Background Element -->
          <div class="absolute -top-20 -right-20 w-48 h-48 bg-indigo-500/10 blur-[100px] rounded-full animate-pulse-slow -z-10"></div>
        </div>
      </div>
    </div>
  </div>
</section>
