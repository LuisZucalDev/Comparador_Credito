<section class="bg-gradient-to-br from-navy-50 to-blue-50 border-b border-gray-100/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
      <!-- Hero Content -->
      <div class="lg:pr-16 fade-in">
        <div class="inline-flex items-center px-5 py-2.5 rounded-full text-sm font-bold bg-gradient-to-r from-green-100 to-emerald-100 text-green-800 border border-green-200 mb-8 shadow-lg">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
          </svg>
          Datos de 6 bancos chilenos · Actualizado hoy
        </div>
        
        <h1 class="text-5xl lg:text-6xl xl:text-7xl font-black text-gray-900 leading-tight mb-8 bg-gradient-to-r from-gray-900 via-navy-600 to-blue-600 bg-clip-text">
          El mejor <span class="text-transparent bg-gradient-to-r from-emerald-500 to-green-600 bg-clip-text">Comparador</span><br>
          de Créditos Chile
        </h1>
        
        <p class="text-xl lg:text-2xl text-gray-600 mb-12 max-w-xl leading-relaxed">
          Compare CAE, tasas y condiciones en segundos. Encuentre el crédito perfecto para usted con datos reales de Banco Estado, BCI, Santander y más.
        </p>
        
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          <div class="bg-white/70 backdrop-blur-sm rounded-2xl p-8 border border-white/50 shadow-xl hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
            <div class="text-4xl lg:text-5xl font-black text-emerald-600 mb-2"><%= stats ? stats.total : '25+' %></div>
            <div class="text-sm font-bold text-gray-600 uppercase tracking-wider">Ofertas Activas</div>
          </div>
          <div class="bg-white/70 backdrop-blur-sm rounded-2xl p-8 border border-white/50 shadow-xl hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
            <div class="text-4xl lg:text-5xl font-black text-orange-500 mb-2"><%= stats ? stats.mejorCAE : '11.8%' %></div>
            <div class="text-sm font-bold text-gray-600 uppercase tracking-wider">Mejor CAE Hoy</div>
          </div>
          <div class="bg-white/70 backdrop-blur-sm rounded-2xl p-8 border border-white/50 shadow-xl hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
            <div class="text-4xl lg:text-5xl font-black text-blue-600 mb-2">6</div>
            <div class="text-sm font-bold text-gray-600 uppercase tracking-wider">Bancos Analizados</div>
          </div>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#filtros" class="group inline-flex items-center justify-center px-10 py-5 bg-gradient-to-r from-navy-600 to-blue-600 hover:from-navy-700 hover:to-blue-700 text-white font-black text-xl rounded-2xl transition-all duration-300 shadow-2xl hover:shadow-3xl hover:-translate-y-1 w-full sm:w-auto transform">
            <svg class="w-6 h-6 mr-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
            </svg>
            Buscar Mi Crédito Ideal
          </a>
        </div>
      </div>
      
      <!-- Visual Mockup -->
      <div class="relative lg:pl-16 fade-in" style="animation-delay: 0.2s;">
        <div class="bg-white/60 backdrop-blur-xl rounded-3xl p-10 lg:p-16 border border-white/40 shadow-2xl max-w-md mx-auto lg:mx-0 hover:shadow-3xl transition-all duration-500 hover:scale-[1.02]">
          <h3 class="text-2xl font-black text-gray-900 mb-8 text-center bg-gradient-to-r from-gray-900 to-navy-600 bg-clip-text">Ejemplo Resultados</h3>
          <div class="space-y-4">
            <% if (creditos && creditos.length > 0) { %>
              <% creditos.slice(0, 3).forEach((credito, index) => { %>
                <div class="flex items-center p-4 bg-white/50 rounded-xl border border-gray-200 hover:bg-white transition-all hover:shadow-md hover:-translate-y-1 <% if (index === 0) { %>ring-4 ring-emerald-200/50<% } %>">
                  <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-green-600 rounded-2xl flex items-center justify-center mr-4 shadow-lg">
                    <span class="text-2xl font-bold text-white"><%= ['🏛️','🏦','🏢'][index % 3] %></span>
                  </div>
                  <div class="flex-1">
                    <div class="font-black text-lg text-gray-900"><%= credito.banco %></div>
                    <div class="flex items-center space-x-4 text-sm">
                      <span class="px-3 py-1 bg-emerald-100 text-emerald-800 font-bold rounded-full text-xs"><%= credito.cae %></span>
                      <span class="text-gray-600"><%= credito.tasa %> / <%= credito.plazo %>m</span>
                    </div>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <div class="text-center py-12 text-gray-500">
                <svg class="w-16 h-16 mx-auto mb-4 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Aplica filtros para ofertas
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

