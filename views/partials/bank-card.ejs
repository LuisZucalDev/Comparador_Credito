<% 
  const caeNum = parseFloat(credito.cae.replace('%', ''));
  const { color, icon, gradient } = credito.config;
  
  // Calculate market comparison status
  const caes = allCreditos.map(c => parseFloat(c.cae.replace('%', '')));
  const minCae = Math.min(...caes);
  const avgCae = caes.reduce((a, b) => a + b, 0) / caes.length;
%>

<div class="relative group/card hover-lift fade-in" style="animation-delay: <%= index * 0.1 %>s;">
  <div class="glass-elite p-6 sm:p-8 lg:p-10 border-white/30 shadow-executive hover:shadow-soft-glow transition-all duration-700 group md:hover:scale-[1.02] rounded-4xl sm:rounded-6xl overflow-hidden">
    
    <!-- Dynamic Background Ambient -->
    <div class="absolute inset-0 bg-gradient-to-br <%= gradient %> opacity-0 group-hover/card:opacity-100 transition-opacity duration-1000"></div>

    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-10 lg:gap-12 relative">
      <!-- Elite Brand Accent -->
      <div class="absolute inset-x-0 -top-12 lg:-top-12 h-[3px] bg-gradient-to-r from-transparent via-<%= color %> to-transparent opacity-30 group-hover/card:opacity-100 transition-opacity duration-700"></div>
      
      <!-- Bank Brand Identity -->
      <div class="flex items-center space-x-6 sm:space-x-8 mb-8 lg:mb-0 lg:w-64">
        <div class="w-16 h-16 sm:w-20 sm:h-20 bg-white dark:bg-slate-800 rounded-3xl md:rounded-[1.8rem] flex items-center justify-center text-4xl sm:text-5xl shadow-elite group-hover/card:scale-110 group-hover/card:rotate-6 transition-all duration-700">
          <span class="filter drop-shadow-md"><%= icon %></span>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center space-x-3 mb-2">
             <% if (caeNum === minCae) { %>
               <span class="px-2.5 py-1 bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 text-[8px] font-black uppercase tracking-[0.2em] rounded-lg border border-emerald-500/20"><%= t('comparador.insights.leader') %></span>
             <% } else if (caeNum < avgCae) { %>
               <span class="px-2.5 py-1 bg-navy-500/10 text-navy-600 dark:text-navy-400 text-[8px] font-black uppercase tracking-[0.2em] rounded-lg border border-navy-500/20"><%= t('comparador.insights.recommended') %></span>
             <% } %>
          </div>
          <div class="text-xl sm:text-2xl font-display font-black text-slate-900 dark:text-white tracking-tighter uppercase mb-2 leading-tight uppercase"><%= t('banks.' + credito.banco) %></div>
          <div class="flex items-center space-x-3">
            <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse shadow-glow-emerald"></span>
            <span class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.3em]"><%= t('comparador.verified') %></span>
          </div>
        </div>
      </div>
      
      <!-- Elite Stats Inventory -->
      <div class="flex-1 border-t lg:border-t-0 lg:border-l border-slate-100 dark:border-slate-800 pt-8 lg:pt-0 lg:pl-16">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 sm:gap-14 lg:gap-20 mb-10">
          <div>
            <div class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-3"><%= t('comparador.best_cae_col') %></div>
            <div class="text-4xl lg:text-5xl font-display font-black text-<%= caeNum <= 12 ? 'emerald' : (caeNum > 14 ? 'rose' : 'navy') %>-600 dark:text-<%= caeNum <= 12 ? 'emerald' : (caeNum > 14 ? 'rose' : 'navy') %>-400 tracking-tighter tabular-nums"><%= credito.cae %></div>
          </div>
          <div>
            <div class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-3"><%= t('comparador.rate_term_col') %></div>
            <div class="text-2xl lg:text-3xl font-display font-black text-slate-900 dark:text-white tracking-tight flex items-baseline">
              <span class="tabular-nums"><%= credito.tasa %></span>
              <span class="mx-3 text-slate-300 dark:text-slate-700 text-xl font-light">/</span>
              <span class="text-slate-400 dark:text-slate-600 text-lg lg:text-xl font-medium"><%= credito.plazo %>m</span>
            </div>
          </div>
          <div class="sm:col-span-2 lg:col-span-1">
            <div class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-3"><%= t('comparador.max_amount_col') %></div>
            <div class="text-2xl lg:text-3xl font-display font-black text-slate-900 dark:text-white tracking-tight tabular-nums"><%= credito.monto %></div>
          </div>
        </div>

        <!-- CAE Thermometer (Market Position) -->
        <div class="space-y-4 max-w-full lg:max-w-md">
          <div class="flex justify-between items-center text-[8px] font-black text-slate-400 dark:text-slate-600 uppercase tracking-[0.2em]">
            <span>Market Position Score</span>
            <span class="text-slate-500"><%= caeNum < avgCae ? 'Premium Offering' : 'Standard Market Rate' %></span>
          </div>
          <div class="cae-thermometer h-1.5 bg-slate-100 dark:bg-white/5 rounded-full overflow-hidden">
            <% 
              const percentage = Math.max(10, Math.min(90, ((caeNum - 8) / (18 - 8)) * 100)); 
            %>
            <div class="cae-thermometer-fill h-full bg-gradient-to-r from-emerald-400 to-navy-500 shadow-glow-emerald transition-all duration-1000" style="width: <%= 100 - percentage %>%"></div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Action Command Center -->
    <div class="mt-12 lg:mt-16 flex flex-col sm:flex-row items-center justify-between lg:justify-end gap-10 lg:gap-16 border-t border-slate-100 dark:border-slate-800/50 pt-10 lg:pt-12">
      <label class="flex items-center cursor-pointer group/toggle self-start sm:self-center transition-all duration-300 hover:scale-105 active:scale-95">
        <div class="relative">
          <input type="checkbox" class="sr-only compare-checkbox" 
            data-bank="<%= t('banks.' + credito.banco) %>" 
            data-cae="<%= credito.cae %>" 
            data-tasa="<%= credito.tasa %>"
            data-icon="<%= icon %>">
          <div class="w-14 h-8 bg-slate-200 dark:bg-slate-800 rounded-full transition-all duration-500 group-hover/toggle:bg-navy-500/30 overflow-hidden relative">
             <div class="absolute inset-0 bg-gradient-to-r from-indigo-500 to-sky-500 opacity-0 transition-opacity duration-500 checkbox-indicator"></div>
          </div>
          <div class="dot w-6 h-6 bg-white dark:bg-slate-100 rounded-full absolute left-1 top-1 transition-all duration-500 shadow-xl flex items-center justify-center">
            <svg class="w-3.5 h-3.5 text-indigo-600 opacity-0 transition-opacity duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 13l4 4L19 7"/></svg>
          </div>
        </div>
        <span class="ml-4 text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.3em] group-hover/toggle:text-navy-600 dark:group-hover/toggle:text-white transition-colors">Select for Comparison</span>
      </label>
      
      <a href="#" class="btn-executive w-full sm:w-auto px-8 py-5 bg-navy-900 text-white dark:bg-white dark:text-navy-900 shadow-executive group/btn overflow-hidden relative text-center">
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover/btn:translate-x-full transition-transform duration-1000"></div>
        <span class="relative z-10 text-[10px] font-black uppercase tracking-widest"><%= t('comparador.contact_bank') %></span>
      </a>
    </div>

  </div>
</div>
