        <a href="/faq" class="text-lg font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors px-3 py-2 rounded-md border-b-2 border-transparent hover:border-blue-500">FAQ</a>
        <a href="/glosario" class="text-lg font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors px-3 py-2 rounded-md border-b-2 border-transparent hover:border-blue-500">Glosario</a>
        <!-- Idioma -->
        <div class="flex items-center space-x-1">
