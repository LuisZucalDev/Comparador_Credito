<div class="blob-container">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
</div>

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-[110] transition-all duration-700 py-6">
  <!-- Shimmer Activity Bar -->
  <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-navy-400 to-transparent opacity-20 animate-shimmer pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="glass-elite rounded-full px-8 lg:px-14 h-20 md:h-24 flex justify-between items-center group/nav border-white/40 dark:border-slate-800/40 shadow-soft-glow">
      <!-- Logo Elite -->
      <div class="flex-shrink-0 flex items-center group cursor-pointer relative">
        <div class="w-12 h-12 md:w-14 md:h-14 bg-gradient-to-br from-slate-900 to-navy-800 dark:from-white dark:to-slate-100 rounded-3xl flex items-center justify-center shadow-elite group-hover:rotate-[10deg] group-hover:scale-110 transition-all duration-700 ease-out relative z-10">
          <span class="text-white dark:text-slate-900 font-display font-black text-2xl md:text-3xl">C</span>
        </div>
        <div class="absolute inset-0 bg-indigo-500/20 blur-2xl rounded-full scale-0 group-hover:scale-125 transition-all duration-700"></div>
        <div class="ml-6 overflow-hidden">
          <a href="/comparador" class="block text-xl md:text-2xl font-display font-black text-slate-900 dark:text-white tracking-widest leading-none group-hover:translate-x-1 transition-transform uppercase">
            <%= t('common.title') %>
          </a>
          <div class="flex items-center space-x-2 mt-1.5">
            <span class="text-[9px] font-black text-navy-500 dark:text-navy-400 uppercase tracking-[0.4em] opacity-60"><%= t('common.subtitle') %></span>
            <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse shadow-glow-emerald"></span>
          </div>
        </div>
      </div>
      
      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center space-x-2">
        <a href="/comparador" class="nav-link-executive group">
          <span class="relative z-10"><%= t('navbar.comparador') %></span>
        </a>
        <a href="/faq" class="nav-link-executive group">
          <span class="relative z-10"><%= t('navbar.faq') %></span>
        </a>
        <a href="/glosario" class="nav-link-executive group">
          <span class="relative z-10"><%= t('navbar.glosario') %></span>
        </a>
        
        <div class="w-px h-8 bg-slate-200 dark:bg-slate-800 mx-6 opacity-50"></div>

        <!-- Language Dropdown Elite -->
        <div class="relative group/lang">
          <button class="flex items-center space-x-3 px-5 py-3 rounded-2xl hover:bg-white/10 dark:hover:bg-slate-800/30 transition-all duration-300">
            <span class="text-xl filter grayscale group-hover/lang:grayscale-0 transition-all scale-110">
              <%= currentLang === 'es' ? '🇪🇸' : currentLang === 'en' ? '🇺🇸' : '🇫🇷' %>
            </span>
            <span class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em]"><%= currentLang %></span>
            <svg class="w-4 h-4 text-slate-300 group-hover/lang:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          
          <div class="absolute right-0 mt-5 w-56 bg-white/95 dark:bg-slate-900/95 backdrop-blur-[50px] rounded-[2rem] shadow-elite border border-white/40 dark:border-slate-800/50 opacity-0 invisible group-hover/lang:opacity-100 group-hover/lang:visible transition-all duration-500 translate-y-4 group-hover/lang:translate-y-0 p-4 z-50">
            <div class="space-y-1.5">
              <a href="?lang=es" class="flex items-center justify-between px-5 py-4 rounded-2xl hover:bg-navy-50/50 dark:hover:bg-slate-800 transition-all group/item">
                <div class="flex items-center space-x-4">
                  <span class="text-xl group-hover/item:scale-125 transition-transform">🇪🇸</span>
                  <span class="text-sm font-bold text-slate-700 dark:text-slate-200 uppercase tracking-tight">Español</span>
                </div>
                <% if (currentLang === 'es') { %><div class="w-1.5 h-1.5 bg-navy-500 rounded-full shadow-glow-navy anim-pulse"></div><% } %>
              </a>
              <a href="?lang=en" class="flex items-center justify-between px-5 py-4 rounded-2xl hover:bg-navy-50/50 dark:hover:bg-slate-800 transition-all group/item">
                <div class="flex items-center space-x-4">
                  <span class="text-xl group-hover/item:scale-125 transition-transform">🇺🇸</span>
                  <span class="text-sm font-bold text-slate-700 dark:text-slate-200 uppercase tracking-tight">English</span>
                </div>
                <% if (currentLang === 'en') { %><div class="w-1.5 h-1.5 bg-navy-500 rounded-full shadow-glow-navy anim-pulse"></div><% } %>
              </a>
              <a href="?lang=fr" class="flex items-center justify-between px-5 py-4 rounded-2xl hover:bg-navy-50/50 dark:hover:bg-slate-800 transition-all group/item">
                <div class="flex items-center space-x-4">
                  <span class="text-xl group-hover/item:scale-125 transition-transform">🇫🇷</span>
                  <span class="text-sm font-bold text-slate-700 dark:text-slate-200 uppercase tracking-tight">Français</span>
                </div>
                <% if (currentLang === 'fr') { %><div class="w-1.5 h-1.5 bg-navy-500 rounded-full shadow-glow-navy anim-pulse"></div><% } %>
              </a>
            </div>
          </div>
        </div>

        <!-- Theme Toggle Elite -->
        <button id="dark-toggle" class="ml-4 p-4 rounded-2xl hover:bg-white/10 dark:hover:bg-slate-800/30 transition-all duration-700 text-slate-400 dark:text-slate-500 group/theme relative overflow-hidden active:scale-90">
          <div class="relative w-6 h-6 flex items-center justify-center">
            <svg id="sun-icon" class="w-6 h-6 absolute hidden dark:block text-slate-100 group-hover/theme:rotate-180 transition-transform duration-1000" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.706a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"/>
            </svg>
            <svg id="moon-icon" class="w-6 h-6 absolute dark:hidden text-slate-800 group-hover/theme:-rotate-[25deg] transition-transform duration-1000" fill="currentColor" viewBox="0 0 20 20">
              <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
            </svg>
          </div>
        </button>
      </div>
      
      <!-- Mobile Toggle -->
      <div class="md:hidden">
        <button id="mobile-menu-btn" class="p-4 rounded-[1.5rem] text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 8h16M4 16h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
  
  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden mx-4 mt-4">
    <div class="glass-card-luxury rounded-[2.5rem] p-8 space-y-4 slide-up shadow-2xl">
      <a href="/comparador" class="block px-6 py-4 text-xl font-display font-black text-slate-800 dark:text-white hover:bg-slate-100 dark:hover:bg-slate-800 rounded-2xl transition-all"><%= t('navbar.comparador') %></a>
      <a href="/faq" class="block px-6 py-4 text-xl font-display font-black text-slate-800 dark:text-white hover:bg-slate-100 dark:hover:bg-slate-800 rounded-2xl transition-all"><%= t('navbar.faq') %></a>
      <a href="/glosario" class="block px-6 py-4 text-xl font-display font-black text-slate-800 dark:text-white hover:bg-slate-100 dark:hover:bg-slate-800 rounded-2xl transition-all"><%= t('navbar.glosario') %></a>
      
      <div class="pt-6 border-t border-slate-200 dark:border-slate-800 flex justify-between items-center">
        <div class="flex space-x-6">
          <a href="?lang=es" class="text-3xl grayscale hover:grayscale-0 transition-all">🇪🇸</a>
          <a href="?lang=en" class="text-3xl grayscale hover:grayscale-0 transition-all">🇺🇸</a>
          <a href="?lang=fr" class="text-3xl grayscale hover:grayscale-0 transition-all">🇫🇷</a>
        </div>
      </div>
    </div>
  </div>
</nav>

<script src="/js/nav.js"></script>
