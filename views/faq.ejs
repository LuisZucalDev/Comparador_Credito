<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Preguntas Frecuentes - Comparador Créditos</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,typography,aspect-ratio"></script>
<script>
 tailwind.config = {
  theme: {
    extend: {
      colors: {
        navy: {
          50: '#eff6ff',
          500: '#3b82f6', 
          600: '#2563eb',
          700: '#1d4ed8'
        }
      }
    }
  }
 }
</script>


</head>
<body class="bg-gray-50 min-h-screen">
<%- include('partials/navbar_professional') %>
  
  <!-- Hero específico FAQ -->
  <section class="bg-gradient-to-r from-navy-900/5 to-blue-900/5 border-b border-gray-100 py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4 fade-in">
        Preguntas Frecuentes ( <%= faqs.length %> )
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
        Respuestas claras y detalladas a las dudas más comunes sobre créditos bancarios
      </p>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="space-y-1 mb-12">
      <h2 class="text-2xl font-bold text-gray-900">Créditos de Consumo</h2>
      <p class="text-gray-600">Temas más consultados por nuestros usuarios</p>
    </div>

    <% if (faqs.length === 0) { %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-16 text-center">
        <svg class="w-20 h-20 text-gray-400 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">No hay preguntas frecuentes</h3>
        <p class="text-gray-600 mb-8">Pronto agregaremos las preguntas más comunes.</p>
      </div>
    <% } else { %>
      <div class="space-y-4">
        <% faqs.forEach((faq, index) => { %>
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 hover:shadow-md hover:border-navy-200 transition-all duration-200 hover-lift">
            <button class="w-full text-left p-8 hover:bg-gray-50 rounded-xl focus:outline-none focus:ring-2 focus:ring-navy-500">
              <div class="flex items-start space-x-4">
                <div class="flex-shrink-0 w-10 h-10 bg-navy-100 rounded-lg flex items-center justify-center mt-1">
                  <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-xl font-bold text-gray-900 mb-3"><%= faq.pregunta %></h3>
                  <div class="text-gray-700 leading-relaxed space-y-2">
                    <%= faq.respuesta.split('\n').join('</p><p class="mt-2">') %>
                  </div>
                </div>
              </div>
            </button>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>

<%- include('partials/footer_professional') %>
  
  <!-- animations.css served -->
</body>
</html>

