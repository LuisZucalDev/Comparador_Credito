<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= t('navbar.glosario') %> - <%= t('common.title') %></title>
  <link href="/css/tailwind.css" rel="stylesheet">
  <link href="/css/animations.css" rel="stylesheet">
</head>
<body class="bg-slate-50 dark:bg-slate-950 transition-colors duration-500 min-h-screen flex flex-col font-sans overflow-x-hidden">
  
  <%- include('partials/navbar') %>
  
  <!-- Hero Glosario Executive Mobile Optimized -->
  <section class="relative min-h-[60vh] md:min-h-[70vh] flex items-center pt-28 pb-12 sm:pt-32 sm:pb-24 overflow-hidden border-b border-slate-200 dark:border-slate-800 bg-white/30 dark:bg-slate-900/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 slide-up">
      <div class="max-w-3xl mx-auto">
        <div class="inline-flex items-center px-4 py-1.5 sm:px-6 sm:py-3 bg-navy-900 dark:bg-white text-white dark:text-navy-900 font-display font-black rounded-xl md:rounded-2xl text-[9px] sm:text-xs shadow-executive mb-8 sm:mb-12 tracking-[0.2em] sm:tracking-[0.3em] uppercase">Executive Database</div>
        <h1 class="text-4xl sm:text-6xl lg:text-9xl font-display font-black text-slate-900 dark:text-white mb-6 sm:mb-10 tracking-[0.05em] uppercase leading-[0.95] font-oswald animate-fade-in break-words">
          <%= t('glosario.title') %>
        </h1>
        <p class="text-base sm:text-xl lg:text-2xl text-slate-500 dark:text-slate-400 leading-relaxed mb-10 sm:mb-16 font-medium max-w-2xl mx-auto">
          <%= t('glosario.description') %>
        </p>
        <div class="relative max-w-2xl mx-auto group/search">
          <input type="text" id="search-glosario" placeholder="<%= t('glosario.search_placeholder') %>" 
            class="w-full px-8 py-5 sm:px-12 sm:py-8 bg-white dark:bg-slate-900/80 backdrop-blur-3xl border-2 border-slate-100 dark:border-slate-800 rounded-2xl md:rounded-[2.5rem] text-xl sm:text-2xl font-display font-bold shadow-luxury focus:ring-8 md:focus:ring-12 focus:ring-navy-600/5 focus:border-navy-600 dark:focus:border-navy-400 transition-all text-slate-900 dark:text-white">
          <div class="absolute right-6 sm:right-10 top-1/2 -translate-y-1/2 flex items-center space-x-3 sm:space-x-4">
             <div class="w-px h-6 sm:h-8 bg-slate-200 dark:bg-slate-800 hidden sm:block"></div>
             <svg class="w-7 h-7 sm:w-10 sm:h-10 text-slate-100 dark:text-slate-900 group-focus-within/search:text-navy-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Glosario Display Mobile Optimized -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-32 flex-grow">
    <div id="glosario-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-16">
      
      <% glosario.forEach((term, index) => { %>
        <div class="group glass-card rounded-2xl md:rounded-[3rem] border-white shadow-executive hover:shadow-luxury transition-all duration-700 overflow-hidden cursor-pointer hover-glosario slide-up" style="animation-delay: <%= index * 0.05 %>s;">
          <div class="p-8 sm:p-12 hover:bg-gradient-to-br hover:from-white/50 hover:to-navy-50/10 dark:hover:from-slate-800/50 dark:hover:to-navy-900/10 h-full flex flex-col items-center text-center">
            
            <div class="w-16 h-16 sm:w-24 sm:h-24 bg-navy-900 dark:bg-white text-white dark:text-navy-900 rounded-2xl md:rounded-[2rem] flex items-center justify-center font-display font-black text-2xl sm:text-4xl shadow-luxury group-hover:rotate-12 transition-transform duration-500 mb-8 sm:mb-10">
              <%= t(term.t_key).charAt(0).toUpperCase() %>
            </div>
            
            <h3 class="text-2xl sm:text-3xl font-display font-black text-slate-900 dark:text-white mb-4 sm:mb-6 uppercase tracking-widest line-clamp-2 leading-none"><%= t(term.t_key) %></h3>
            
            <div class="w-10 h-1 bg-gradient-to-r from-navy-600 to-indigo-600 rounded-full mb-8 sm:mb-10 opacity-40 group-hover:w-16 sm:group-hover:w-20 group-hover:opacity-100 transition-all duration-500"></div>
            
            <p class="text-base sm:text-xl text-slate-500 dark:text-slate-400 leading-relaxed font-medium line-clamp-4 sm:line-clamp-3 group-hover:line-clamp-none transition-all duration-1000 flex-grow"><%= t(term.d_key) %></p>
            
            <div class="mt-8 sm:mt-12 pt-8 sm:pt-10 border-t border-slate-100 dark:border-slate-800 w-full flex items-center justify-between opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-2 group-hover:translate-y-0">
              <span class="text-[8px] sm:text-[10px] text-slate-300 dark:text-slate-700 font-black uppercase tracking-[0.3em]">Executive Grade</span>
              <div class="flex items-center space-x-2 sm:space-x-3 text-navy-600 dark:text-navy-400">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-tight"><%= t('glosario.learn_more') %></span>
                <svg class="w-4 h-4 sm:w-5 sm:h-5 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
      
    </div>

    <!-- Empty Search State Mobile Optimized -->
    <div id="no-results" class="hidden text-center py-24 sm:py-48 fade-in">
      <div class="w-32 h-32 sm:w-40 sm:h-40 bg-slate-100 dark:bg-slate-900 rounded-2xl md:rounded-[2.5rem] flex items-center justify-center mx-auto mb-10 shadow-executive">
        <svg class="w-16 h-16 sm:w-20 sm:h-20 text-slate-200 dark:text-slate-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </div>
      <h3 class="text-3xl sm:text-5xl font-display font-black text-slate-900 dark:text-white mb-6 uppercase tracking-tighter"><%= t('glosario.no_results') %></h3>
      <p class="text-lg sm:text-2xl text-slate-400 dark:text-slate-600 mb-12 sm:mb-16 max-w-xl mx-auto font-medium leading-relaxed uppercase tracking-widest text-[9px] sm:text-xs"><%= t('glosario.no_results_desc') %></p>
      <button onclick="clearSearch()" class="btn-executive text-lg sm:text-xl px-12 sm:px-16 py-5 sm:py-6 shadow-luxury">
        <%= t('glosario.clear_btn') %>
      </button>
    </div>
    
  </main>

  <%- include('partials/footer') %>

  <script>
    const searchInput = document.getElementById('search-glosario');
    const grid = document.getElementById('glosario-grid');
    const items = grid.querySelectorAll('.hover-glosario');
    const noResults = document.getElementById('no-results');
    
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase();
        let visibleCount = 0;
        
        items.forEach(item => {
          const title = item.querySelector('h3').textContent.toLowerCase();
          const content = item.querySelector('p').textContent.toLowerCase();
          const isVisible = title.includes(term) || content.includes(term);
          
          item.style.display = isVisible ? 'block' : 'none';
          if (isVisible) {
            visibleCount++;
          }
        });
        
        if (visibleCount === 0) {
          grid.classList.add('hidden');
          noResults.classList.remove('hidden');
        } else {
          grid.classList.remove('hidden');
          noResults.classList.add('hidden');
        }
      });
    }
    
    function clearSearch() {
      searchInput.value = '';
      items.forEach(item => item.style.display = 'block');
      noResults.classList.add('hidden');
      grid.classList.remove('hidden');
    }
  </script>
</body>
</html>
