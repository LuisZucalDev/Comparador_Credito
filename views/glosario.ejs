<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Glosario Financiero - Comparador Créditos</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,typography,aspect-ratio"></script>
<script>
 tailwind.config = {
  theme: {
    extend: {
      colors: {
        navy: {
          50: '#eff6ff',
          500: '#3b82f6', 
          600: '#2563eb',
          700: '#1d4ed8'
        }
      }
    }
  }
 }
</script>


</head>
<body class="bg-gray-50 min-h-screen">
<%- include('partials/navbar_professional') %>
  
  <!-- Hero específico Glosario -->
  <section class="bg-gradient-to-r from-slate-900/5 to-navy-900/5 border-b border-gray-100 py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4 fade-in">
        Glosario Financiero ( <%= glosario.length %> términos )
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Términos técnicos del mundo de los créditos explicados de forma clara y precisa
      </p>
    </div>
  </section>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Search -->
    <div class="mb-12">
      <div class="relative max-w-md mx-auto">
        <input type="text" id="searchGlossary" placeholder="Buscar término (ej: CAE)..." 
               class="w-full pl-12 pr-4 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-navy-500 focus:border-navy-500 transition-all shadow-sm text-lg">
        <svg class="absolute left-4 top-1/2 transform -translate-y-1/2 w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>
    </div>

    <% if (glosario.length === 0) { %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-16 text-center">
        <svg class="w-20 h-20 text-gray-400 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
        </svg>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Glosario vacío</h3>
        <p class="text-gray-600 mb-8">No hay términos disponibles en este momento.</p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% glosario.sort((a,b) => a.termino.localeCompare(b.termino)).forEach((item, index) => { %>
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 hover:shadow-md hover:border-navy-200 transition-all duration-200 hover-lift group">
            <div class="p-8">
              <div class="flex items-start space-x-4 mb-4">
                <div class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-navy-500 to-navy-600 rounded-xl flex items-center justify-center text-white font-bold text-lg shadow-md">
                  <%= item.termino.charAt(0).toUpperCase() %>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-2xl font-black text-gray-900 group-hover:text-navy-600 transition-colors mb-2 line-clamp-2">
                    <%= item.termino %>
                  </h3>
                  <p class="text-gray-700 leading-relaxed text-base"><%= item.definicion %></p>
                </div>
              </div>
              <span class="inline-block bg-navy-50 text-navy-700 text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wide">
                Término clave
              </span>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>

<%- include('partials/footer_professional') %>
  
  <!-- animations.css served -->
  
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('searchGlossary');
      const cards = document.querySelectorAll('[class*="grid"] > div');
      
      searchInput.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase();
        cards.forEach(card => {
          const term = card.querySelector('h3').textContent.toLowerCase();
          card.style.display = term.includes(query) || query.length === 0 ? 'block' : 'none';
        });
      });
    });
  </script>
</body>
</html>

