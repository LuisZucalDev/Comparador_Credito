<!DOCTYPE html>
<html lang="<%= currentLang %>" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= t('common.title') %> - Comparison Dashboard</title>
  <link href="/css/tailwind.css" rel="stylesheet">
  <link href="/css/animations.css" rel="stylesheet">
</head>
<body class="bg-slate-50 dark:bg-slate-950 transition-colors duration-500 min-h-screen flex flex-col font-sans overflow-x-hidden">
  
  <%- include('partials/navbar') %>
  <%- include('partials/hero') %>

  <!-- Mobile Filter Toggle (Floating) -->
  <div class="lg:hidden fixed bottom-6 right-6 z-[90] animate-bounce">
    <button id="open-filters" class="flex items-center space-x-3 px-6 py-4 bg-navy-900 dark:bg-white text-white dark:text-navy-900 rounded-full shadow-luxury font-black uppercase text-xs tracking-widest border border-white/20">
      <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
      <span><%= t('comparador.filters_title') %></span>
    </button>
  </div>

  <main id="filtros" class="max-w-7xl 2xl:max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24 -mt-12 md:-mt-24 lg:-mt-32 relative z-20 flex-grow w-full">
    <div class="grid lg:grid-cols-4 2xl:grid-cols-5 lg:gap-16 items-start">
      
      <!-- Sidebar: Executive Control Center -->
      <aside id="filter-sidebar" class="fixed inset-0 z-[100] translate-y-full opacity-0 invisible lg:relative lg:inset-auto lg:z-auto lg:translate-y-0 lg:opacity-100 lg:visible transition-all duration-700 lg:col-span-1 lg:sticky lg:top-32 mb-16 lg:mb-0">
        <!-- Backdrop Mobile -->
        <div id="close-filters-area" class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm lg:hidden"></div>
        
        <div class="relative w-full max-w-xs ml-auto h-full lg:h-auto overflow-y-auto lg:overflow-visible bg-white dark:bg-slate-950 lg:bg-transparent p-6 sm:p-10 lg:p-0">
          <div class="glass-elite p-6 sm:p-8 lg:p-10 border-white/40 shadow-soft-glow relative overflow-hidden group/sidebar rounded-4xl sm:rounded-6xl">
            <!-- Shimmer Industry Bar -->
            <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-navy-400 to-transparent opacity-20 animate-shimmer"></div>
            
            <div class="flex items-center justify-between mb-10">
              <h2 class="text-xl sm:text-2xl font-display font-black text-slate-900 dark:text-white uppercase tracking-tighter leading-tight pr-4"><%= t('comparador.filters') %></h2>
              <button id="close-filters-btn" class="lg:hidden p-3 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
            
            <form id="filter-form" action="/comparador" method="GET" class="space-y-10">
              <!-- Term Elite Select -->
              <div class="group/input">
                <label class="block text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.3em] mb-4 group-hover/input:text-navy-600 transition-colors"><%= t('comparador.term_label') %></label>
                <div class="relative">
                  <select name="plazo" class="w-full bg-slate-50 dark:bg-slate-800/40 border-2 border-transparent focus:border-navy-500/20 rounded-2xl px-6 py-5 text-sm font-bold text-slate-700 dark:text-slate-200 focus:ring-4 focus:ring-navy-500/10 transition-all appearance-none cursor-pointer">
                    <option value=""><%= t('comparador.all_terms') %></option>
                    <% [12, 24, 36, 48, 60].forEach(p => { %>
                      <option value="<%= p %>" <%= plazo == p ? 'selected' : '' %>><%= p %> meses</option>
                    <% }) %>
                  </select>
                  <div class="absolute right-6 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400 group-hover/input:rotate-180 transition-transform duration-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                  </div>
                </div>
              </div>

              <!-- Amount Elite Input -->
              <div class="group/input">
                <label class="block text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.3em] mb-4 group-hover/input:text-navy-600 transition-colors"><%= t('comparador.amount_label') %></label>
                <div class="relative">
                  <span class="absolute left-6 top-1/2 -translate-y-1/2 text-lg font-black text-slate-300 dark:text-slate-700 group-focus-within/input:text-navy-600 transition-colors">$</span>
                  <input type="number" name="monto" value="<%= monto || '' %>" placeholder="2.000.000" 
                    class="w-full pl-12 pr-6 py-5 bg-slate-50 dark:bg-slate-800/40 border-2 border-transparent focus:border-navy-500/20 rounded-2xl focus:ring-4 focus:ring-navy-500/10 transition-all font-display font-bold text-slate-900 dark:text-white shadow-inner">
                </div>
              </div>

              <div class="pt-6 space-y-4">
                <button type="submit" class="btn-executive w-full py-5 flex items-center justify-center space-x-3 group/btn hover:scale-[1.02]">
                  <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                  <span class="text-xs font-black uppercase tracking-widest"><%= t('comparador.apply_filters') %></span>
                </button>
                <button type="submit" name="limpiar" value="1" class="w-full py-4 text-center text-[10px] font-black text-slate-400 dark:text-slate-600 hover:text-navy-600 dark:hover:text-white uppercase tracking-[0.4em] transition-all"><%= t('comparador.clear_filters') %></button>
              </div>
            </form>
          </div>
        </div>
      </aside>
      
      <!-- Results Area -->
      <section class="lg:col-span-3 2xl:col-span-4">
        
        <% if (creditos.length === 0) { %>
          <div class="glass-card rounded-3xl md:rounded-[3.5rem] p-12 sm:p-20 md:p-32 text-center slide-up shadow-luxury">
            <div class="w-20 h-20 sm:w-24 sm:h-24 bg-slate-50 dark:bg-slate-900 rounded-2xl md:rounded-[2rem] flex items-center justify-center mx-auto mb-10 shadow-executive">
              <svg class="w-10 h-10 sm:w-12 sm:h-12 text-slate-200 dark:text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            </div>
            <h3 class="text-3xl sm:text-4xl font-display font-black text-slate-900 dark:text-white mb-6 uppercase tracking-tighter"><%= t('comparador.no_results') %></h3>
            <p class="text-lg sm:text-xl text-slate-500 dark:text-slate-400 mb-10 max-w-lg mx-auto font-medium leading-relaxed"><%= t('comparador.no_results_desc') %></p>
            <a href="/comparador" class="btn-executive inline-flex items-center px-10 py-4 sm:px-12 sm:py-5">
              <%= t('comparador.view_all') %>
            </a>
          </div>
        <% } else { %>
          
          <div class="grid grid-cols-1 xl:grid-cols-2 2xl:grid-cols-3 gap-8 md:gap-10 slide-up">
            <% creditos.forEach((credito, index) => { %>
              <%- include('partials/bank-card', { credito, index, allCreditos: creditos }) %>
            <% }) %>
          </div>
          
          <!-- Newsletter Mobile Optimized -->
          <div class="glass-card-luxury rounded-3xl md:rounded-[3.5rem] p-8 sm:p-16 lg:p-24 text-center relative overflow-hidden fade-in">
             <div class="absolute inset-0 bg-gradient-to-br from-navy-600/5 to-emerald-500/5 pointer-events-none"></div>
             <div class="relative z-10">
                <div class="inline-flex items-center px-4 py-2 bg-white dark:bg-slate-900/50 text-slate-800 dark:text-slate-200 font-display font-black rounded-xl text-[9px] shadow-executive mb-6 tracking-[0.3em] uppercase">Professional Update</div>
                <h3 class="text-3xl sm:text-4xl lg:text-6xl font-display font-black text-slate-900 dark:text-white mb-6 lg:mb-8 tracking-tighter uppercase leading-tight"><%= t('comparador.alert_title') %></h3>
                <p class="text-base sm:text-xl text-slate-500 dark:text-slate-400 mb-10 lg:mb-14 max-w-xl mx-auto font-medium leading-relaxed"><%= t('comparador.alert_desc') %></p>
                <form id="newsletter-form" class="flex flex-col sm:flex-row gap-4 justify-center max-w-2xl mx-auto">
                  <input type="email" required placeholder="executive@finance.cl" 
                    class="w-full px-8 py-4 sm:py-6 bg-white dark:bg-slate-900/50 border-2 border-slate-100 dark:border-slate-800 rounded-2xl md:rounded-[2rem] text-lg font-display font-bold shadow-inner focus:ring-8 focus:ring-navy-600/5 focus:border-navy-600 dark:focus:border-navy-400 transition-all text-slate-900 dark:text-white">
                  <button type="submit" class="btn-executive px-10 py-4 sm:py-6 text-lg tracking-tight whitespace-nowrap"><%= t('comparador.receive_alerts') %></button>
                </form>
             </div>
          </div>
        <% } %>
      </section>
    </div>
  </main>

  <!-- Elite Comparison Modal -->
  <div id="comparison-modal" class="fixed inset-0 z-[200] opacity-0 invisible transition-all duration-500 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-md" id="close-modal-bg"></div>
    <div class="relative w-full max-w-5xl bg-white dark:bg-slate-950 rounded-[2.5rem] sm:rounded-[4rem] shadow-luxury border border-white/20 overflow-hidden transform scale-95 transition-transform duration-500" id="modal-content">
      <div class="p-8 sm:p-12 lg:p-16">
        <div class="flex items-center justify-between mb-12">
          <h3 class="text-3xl sm:text-4xl font-display font-black text-slate-900 dark:text-white uppercase tracking-tighter">Executive Review</h3>
          <button id="close-modal-btn" class="p-4 rounded-full hover:bg-slate-100 dark:hover:bg-white/5 transition-colors">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div id="modal-comparison-grid" class="grid grid-cols-1 md:grid-cols-3 gap-8">
           <!-- Dynamically populated -->
        </div>
        <div class="mt-16 flex justify-center">
            <button class="btn-executive px-12 py-6 text-xl" onclick="window.print()">Export Analysis Report</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Executive Toast Container -->
  <div id="toast-container" class="fixed top-8 right-8 z-[300] space-y-4 pointer-events-none"></div>

  <div id="compare-drawer" class="fixed bottom-0 left-0 right-0 z-[110] translate-y-full transition-all duration-1000 pointer-events-none pb-12">
    <div class="max-w-5xl mx-auto px-6 pointer-events-auto">
      <div class="glass-card-luxury rounded-full p-6 md:p-8 shadow-luxury border-navy-500/20 overflow-hidden relative group">
        <div class="absolute inset-0 bg-gradient-to-r from-navy-900/95 to-indigo-900/95"></div>
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-6 md:gap-12">
          <div class="flex flex-col text-center md:text-left ml-4">
            <h4 class="text-xl sm:text-2xl font-display font-black text-white tracking-tight leading-none mb-1">Comparison Deck</h4>
            <div class="flex items-center justify-center md:justify-start space-x-2">
              <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
              <p class="text-indigo-200 text-[9px] font-bold uppercase tracking-[0.2em]"><span id="compare-count">0</span> Offerings Selected</p>
            </div>
          </div>
          <div id="compare-items" class="flex flex-1 justify-center space-x-6 overflow-x-auto max-w-full no-scrollbar pb-1 md:pb-0">
            <!-- Items injected by JS -->
          </div>
          <div class="flex items-center space-x-4 mr-4">
             <button id="clear-compare" class="px-6 py-3 text-slate-300 font-black uppercase text-[10px] tracking-widest hover:text-white transition-colors">Reset</button>
             <button id="trigger-comparison" class="btn-executive px-10 py-4 bg-white text-navy-900 shadow-2xl hover:scale-105 active:scale-95 transition-all text-xs">Review & Export</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
    window.ELITE_TRANSLATIONS = <%- JSON.stringify(t('elite', { returnObjects: true })) %>;
  </script>
  <script src="/js/comparador.js"></script>
</body>
</html>
