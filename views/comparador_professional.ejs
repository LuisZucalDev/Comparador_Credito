<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Comparador Créditos ProfesionaI - Mejores Ofertas Chile</title>
  <link href="/css/tailwind.css" rel="stylesheet">
  <link href="/css/animations.css" rel="stylesheet">
  <meta name="description" content="Comparador profesional de créditos bancarios Chile. CAE, tasas y condiciones actualizadas de Banco Estado, BCI, Santander.">
</head>
<body class="bg-gray-50/50 min-h-screen">
  
  <%- include('partials/navbar_professional') %>
  <%- include('partials/hero_professional') %>

  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-12 lg:mt-0">
    <div class="grid lg:grid-cols-4 lg:gap-8">
      
      <!-- Advanced Filters Sidebar -->
      <div class="lg:col-span-1 lg:sticky lg:top-24 lg:max-h-screen lg:overflow-y-auto mb-12 lg:mb-0">
        <div class="bg-white/80 backdrop-blur-sm rounded-3xl shadow-xl border border-white/50 p-8 lg:p-10 sticky top-8">
          <div class="mb-8">
            <h2 class="text-2xl lg:text-3xl font-black text-gray-900 mb-4 bg-gradient-to-r from-navy-600 to-blue-600 bg-clip-text">Filtros Avanzados</h2>
            <div class="w-24 h-1 bg-gradient-to-r from-navy-500 to-blue-500 rounded-full"></div>
          </div>
          
          <form action="/comparador" method="GET" class="space-y-8">
            <!-- Plazo Range Slider -->
            <div>
              <label class="block text-lg font-bold text-gray-900 mb-4">Plazo (meses)</label>
              <select name="plazo" class="w-full p-4 border-2 border-gray-200 rounded-2xl focus:ring-4 focus:ring-navy-200 focus:border-navy-500 transition-all text-lg font-semibold">
                <option value="">Todos los plazos</option>
                <option value="12" <%= plazo == '12' ? 'selected' : '' %>>12 meses</option>
                <option value="24" <%= plazo == '24' ? 'selected' : '' %>>24 meses</option>
                <option value="36" <%= plazo == '36' ? 'selected' : '' %>>36 meses</option>
                <option value="48" <%= plazo == '48' ? 'selected' : '' %>>48 meses</option>
              </select>
            </div>
            
            <!-- Monto Slider -->
            <div>
              <label class="block text-lg font-bold text-gray-900 mb-4">Monto Máximo Solicitado</label>
              <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                  <span class="text-gray-500 text-lg">$</span>
                </div>
                <input type="number" name="monto" value="<%= monto || '' %>" placeholder="2.000.000" 
                  class="w-full pl-12 pr-6 py-4 border-2 border-gray-200 rounded-2xl focus:ring-4 focus:ring-green-200 focus:border-green-500 transition-all text-lg font-semibold shadow-inner" 
                  min="100000" max="5000000" step="100000">
              </div>
              <div class="text-xs text-gray-500 mt-2">Hasta $5.000.000 CLP</div>
            </div>
            
            <!-- CTA Buttons -->
            <div class="grid grid-cols-1 gap-4 pt-4">
              <button type="submit" class="group bg-gradient-to-r from-navy-600 to-blue-600 hover:from-navy-700 hover:to-blue-700 text-white font-black py-5 px-8 rounded-2xl text-lg shadow-2xl hover:shadow-3xl hover:-translate-y-1 transition-all duration-300 w-full flex items-center justify-center">
                <svg class="w-6 h-6 mr-3 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
                </svg>
                Aplicar Filtros Avanzados
              </button>
              <button type="submit" name="limpiar" value="1" class="bg-gradient-to-r from-gray-100 to-gray-200 hover:from-gray-200 hover:to-gray-300 text-gray-800 font-black py-5 px-8 rounded-2xl text-lg shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-300 w-full">
                Limpiar Todos los Filtros
              </button>
            </div>
            
            <% if (total > 0) { %>
              <div class="bg-gradient-to-r from-emerald-500/10 to-green-500/10 border-2 border-emerald-400/30 rounded-2xl p-6 text-center">
                <div class="text-3xl lg:text-4xl font-black text-emerald-700 mb-2"><%= total %></div>
                <div class="text-lg font-bold text-emerald-800">Créditos encontrados</div>
              </div>
            <% } %>
          </form>
        </div>
      </div>
      
      <!-- Results Section -->
      <div class="lg:col-span-3 space-y-8">
        
        <% if (creditos.length === 0) { %>
          <!-- Empty State -->
          <div class="bg-white/70 backdrop-blur-sm rounded-3xl shadow-2xl border border-white/50 p-20 lg:p-32 text-center fade-in">
            <div class="w-32 h-32 bg-gradient-to-br from-gray-200 to-gray-300 rounded-3xl flex items-center justify-center mx-auto mb-8 shadow-xl">
              <svg class="w-16 h-16 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="text-4xl lg:text-5xl font-black text-gray-900 mb-6">Sin resultados</h3>
            <p class="text-xl text-gray-600 mb-12 max-w-2xl mx-auto leading-relaxed">No encontramos créditos que coincidan exactamente con tus filtros. Prueba ajustar los parámetros o elimina algunos filtros para ver todas las opciones disponibles.</p>
            <a href="/comparador" class="inline-flex items-center px-12 py-5 bg-navy-600 hover:bg-navy-700 text-white font-black text-xl rounded-2xl shadow-2xl hover:shadow-3xl hover:-translate-y-1 transition-all duration-300">
              Ver Todas las Ofertas
              <svg class="w-6 h-6 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        <% } else { %>
          
          <!-- Results Header -->
          <div class="bg-white/80 backdrop-blur-sm rounded-3xl shadow-xl border border-white/50 p-8 lg:p-10 fade-in">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
              <div>
                <h2 class="text-3xl lg:text-4xl font-black text-gray-900 mb-2">
                  <%= total %> Ofertas Encontradas
                </h2>
                <p class="text-xl text-gray-600 font-semibold">Ordenadas por mejor CAE · Actualizado hoy</p>
              </div>
              <div class="flex flex-col sm:flex-row gap-3">
                <button class="px-8 py-3 bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold rounded-xl text-lg shadow-md hover:shadow-lg transition-all whitespace-nowrap">
                  Ver Gráfico CAE
                </button>
                <button class="px-8 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-xl text-lg shadow-lg hover:shadow-xl transition-all whitespace-nowrap">
                  Exportar Excel
                </button>
              </div>
            </div>
          </div>
          
          <!-- Credits Table -->
          <div class="bg-white/80 backdrop-blur-sm rounded-3xl shadow-2xl border border-white/50 overflow-hidden fade-in">
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gradient-to-r from-gray-50 to-gray-100/50">
                  <tr>
                    <th class="px-8 py-6 text-left">
                      <div class="font-black text-xl text-gray-900 uppercase tracking-wider flex items-center">
                        Banco <span class="ml-2 text-xs bg-gray-200 px-2 py-1 rounded-full font-bold">6 disponibles</span>
                      </div>
                    </th>
                    <th class="px-8 py-6 text-left">
                      <div class="font-black text-xl text-gray-900 uppercase tracking-wider">Mejor CAE</div>
                    </th>
                    <th class="px-8 py-6 text-left">
                      <div class="font-black text-xl text-gray-900 uppercase tracking-wider">Tasa / Plazo</div>
                    </th>
                    <th class="px-8 py-6 text-left">
                      <div class="font-black text-xl text-gray-900 uppercase tracking-wider">Monto Máx</div>
                    </th>
                    <th class="px-8 py-6 text-right">
                      <div class="font-black text-xl text-gray-900 uppercase tracking-wider">Contacto</div>
                    </th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  <% creditos.forEach((credito, index) => { %>
                    <% 
                      const caeNum = parseFloat(credito.cae.replace('%', ''));
                      let badgeColor = 'bg-emerald-100 text-emerald-800';
                      let icon = '🏦';
                      if (credito.banco.includes('Estado')) icon = '🏛️';
                      else if (credito.banco.includes('Santander')) icon = '🏢';
                      else icon = '🏦';
                      if (caeNum < 12.5) badgeColor = 'bg-emerald-100 text-emerald-800';
                      else if (caeNum < 13.5) badgeColor = 'bg-amber-100 text-amber-800';
                      else badgeColor = 'bg-rose-100 text-rose-800';
                    %>
                    <tr class="hover:bg-gray-50/50 group transition-all hover:shadow-lg hover:-translate-y-0.5 duration-200 hover-lift">
                      <td class="px-8 py-8">
                        <div class="flex items-center space-x-4">
                          <div class="w-16 h-16 bg-gradient-to-br <%= index === 0 ? 'from-emerald-500 to-green-600 ring-4 ring-emerald-200/50' : 'from-gray-500 to-gray-600 ring-2 ring-gray-200/50' %> rounded-2xl flex items-center justify-center shadow-2xl">
                            <span class="text-2xl font-black text-white"><%= icon %></span>
                          </div>
                          <div>
                            <h4 class="text-2xl font-black text-gray-900"><%= credito.banco %></h4>
                            <p class="text-sm text-gray-600 font-medium"><%= index + 1 %>º en ranking CAE</p>
                          </div>
                        </div>
                      </td>
                      <td class="px-8 py-8">
                        <span class="<%= badgeColor %> px-6 py-3 rounded-2xl text-xl font-black shadow-lg uppercase tracking-wide inline-block transform hover:scale-105 transition-all"><%= credito.cae %></span>
                      </td>
                      <td class="px-8 py-8">
                        <div>
                          <div class="text-xl font-bold text-gray-900"><%= credito.tasa %></div>
                          <div class="text-lg text-gray-600 font-semibold"><%= credito.plazo %> meses</div>
                        </div>
                      </td>
                      <td class="px-8 py-8">
                        <div class="text-2xl font-black text-gray-900"><%= credito.monto %></div>
                      </td>
                      <td class="px-8 py-8 text-right">
                        <a href="<%= credito.contacto %>" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center justify-center px-10 py-4 bg-gradient-to-r from-emerald-600 to-green-600 hover:from-emerald-700 hover:to-green-700 text-white font-black text-lg rounded-2xl shadow-2xl hover:shadow-3xl hover:-translate-y-1 transition-all duration-300 transform w-full lg:w-auto">
                          Contactar Banco
                          <svg class="w-6 h-6 ml-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                          </svg>
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
          
          <!-- CTA Final -->
          <div class="text-center py-20 fade-in">
            <svg class="w-24 h-24 text-gray-300 mx-auto mb-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138 3.42 3.42 0 001.946-.806z"/>
            </svg>
            <h3 class="text-3xl font-black text-gray-900 mb-6">¿Encontraste lo que buscabas?</h3>
            <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">Recibe notificaciones cuando cambien las tasas de tu banco favorito.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center max-w-md mx-auto">
              <input type="email" placeholder="tu@email.com" class="flex-1 px-6 py-4 border-2 border-gray-200 rounded-2xl focus:ring-4 focus:ring-navy-200 focus:border-navy-500 text-lg shadow-inner">
              <button class="px-10 py-4 bg-navy-600 hover:bg-navy-700 text-white font-black rounded-2xl text-lg shadow-2xl hover:shadow-3xl hover:-translate-y-1 transition-all whitespace-nowrap">
                Recibir Alertas
              </button>
            </div>
          </div>
          
        <% } %>
      </div>
    </div>
  </main>

  <%- include('partials/footer_professional') %>

</body>
</html>

