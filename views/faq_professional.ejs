<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Preguntas Frecuentes - Comparador Créditos Chile</title>
  <link href="/css/tailwind.css" rel="stylesheet">
  <link href="/css/animations.css" rel="stylesheet">
</head>
<body class="bg-gray-50 min-h-screen">
  
  <%- include('partials/navbar_professional') %>
  
  <!-- Hero FAQ -->
  <section class="bg-gradient-to-br from-blue-50 to-indigo-100 py-32">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl lg:text-7xl font-black text-gray-900 mb-8 bg-gradient-to-r from-navy-600 to-blue-600 bg-clip-text leading-tight">
        Preguntas
        <span class="block text-4xl lg:text-5xl text-gray-700 font-light mt-4">Frecuentes</span>
      </h1>
      <p class="text-xl lg:text-2xl text-gray-600 max-w-3xl mx-auto leading-relaxed mb-12">
        Respuestas a las dudas más comunes sobre créditos de consumo, CAE y cómo usar nuestro comparador profesional.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center max-w-2xl mx-auto">
        <a href="/comparador" class="px-12 py-5 bg-navy-600 hover:bg-navy-700 text-white font-black rounded-2xl shadow-2xl hover:shadow-3xl hover:-translate-y-1 transition-all text-xl">
          Volver al Comparador
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Content -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24 -mt-24 lg:-mt-32">
    <div class="space-y-6">
      
      <% faqs.forEach((faq, index) => { %>
        <div class="group bg-white rounded-3xl shadow-xl border border-gray-200 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 overflow-hidden hover:border-navy-200">
          <div class="p-10 cursor-pointer" onclick="this.parentElement.querySelector('.faq-answer').classList.toggle('open')">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="w-12 h-12 bg-gradient-to-br from-navy-500 to-blue-600 rounded-2xl flex items-center justify-center text-white font-bold text-xl mr-6 shadow-lg group-hover:scale-110 transition-transform">
                  Q<%= (index + 1).toString().padStart(2, '0') %>
                </div>
                <div>
                  <h3 class="text-2xl font-black text-gray-900 group-hover:text-navy-600 transition-colors mb-1 leading-tight"><%= faq.pregunta %></h3>
                  <div class="flex items-center text-emerald-600 font-bold text-lg">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span>Respuesta verificada</span>
                  </div>
                </div>
              </div>
              <div class="flex flex-col items-end">
                <svg class="w-8 h-8 text-gray-400 group-hover:text-navy-600 transition-colors transform group-hover:rotate-180 duration-300" fill="none" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </div>
            </div>
          </div>
          
          <!-- Answer -->
          <div class="faq-answer bg-gradient-to-r from-gray-50 to-blue-50 px-10 py-8 border-t border-gray-200 overflow-hidden transform -translate-y-4 scale-95 opacity-0 group-hover:translate-y-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-500 ease-out open:translate-y-0 open:scale-100 open:opacity-100">
            <div class="prose prose-lg max-w-none">
              <p class="text-xl lg:text-2xl text-gray-800 leading-relaxed"><%= faq.respuesta %></p>
            </div>
            <div class="mt-8 pt-8 border-t border-gray-200">
              <div class="flex flex-wrap gap-3">
                <span class="px-4 py-2 bg-navy-100 text-navy-800 font-bold rounded-xl text-sm shadow-md">Técnico</span>
                <span class="px-4 py-2 bg-emerald-100 text-emerald-800 font-bold rounded-xl text-sm shadow-md">Verificado CMF</span>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
      
    </div>

    <!-- CTA Section -->
    <div class="mt-32 text-center">
      <div class="inline-flex items-center px-8 py-4 bg-emerald-100 text-emerald-800 font-bold rounded-2xl text-xl shadow-xl mb-8">
        <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
        </svg>
        ¿No encontraste tu respuesta?
      </div>
      <h3 class="text-4xl font-black text-gray-900 mb-6">Contáctanos directamente</h3>
      <p class="text-xl text-gray-600 mb-12 max-w-2xl mx-auto">Nuestro equipo experto responde en menos de 24 horas.</p>
      <div class="flex flex-col lg:flex-row gap-6 justify-center max-w-lg mx-auto">
        <a href="mailto:contacto@comparadorcreditos.cl" class="flex items-center justify-center px-10 py-5 bg-navy-600 hover:bg-navy-700 text-white font-black rounded-2xl shadow-2xl hover:shadow-3xl hover:-translate-y-1 transition-all text-xl">
          <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.27 7.27c.883.883 2.317.883 3.2 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Email Soporte
        </a>
      </div>
    </div>
  </main>

  <%- include('partials/footer_professional') %>

  <script>
    // Smooth animations for FAQ accordion
    document.querySelectorAll('[onclick]').forEach(el => {
      el.addEventListener('click', function(e) {
        e.preventDefault();
        const answer = this.parentElement.querySelector('.faq-answer');
        answer.classList.toggle('open');
      });
    });
  </script>
</body>
</html>

